root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{py,pyi}]
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,css,html}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Dockerfile]
indent_style = space
indent_size = 4

[docker-compose.yml]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2
